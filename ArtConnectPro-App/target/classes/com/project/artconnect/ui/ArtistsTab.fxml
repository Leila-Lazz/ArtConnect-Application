<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtistController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search artists..." HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="disciplineFilter" promptText="Filter by Discipline" />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
    </HBox>
    <TableView fx:id="artistTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200" />
            <TableColumn fx:id="cityColumn" text="City" prefWidth="150" />
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="200" />
            <TableColumn fx:id="yearColumn" text="Birth Year" prefWidth="100" />
        </columns>
    </TableView>

    <!-- CRUD Form Section -->
    <VBox spacing="10.0" style="-fx-padding: 10; -fx-border-color: #cccccc; -fx-border-width: 1; -fx-border-radius: 5;">
        <Label text="Manage Artist" style="-fx-font-weight: bold;" />
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="nameInput" promptText="Name" HBox.hgrow="ALWAYS" />
            <TextField fx:id="cityInput" promptText="City" prefWidth="150" />
            <TextField fx:id="emailInput" promptText="Email" prefWidth="200" />
            <TextField fx:id="yearInput" promptText="Birth Year" prefWidth="100" />
        </HBox>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Button text="Add" onAction="#handleAdd" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
            <Button text="Update" onAction="#handleUpdate" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
            <Button text="Delete" onAction="#handleDelete" style="-fx-background-color: #F44336; -fx-text-fill: white;" />
        </HBox>
    </VBox>
</VBox>
